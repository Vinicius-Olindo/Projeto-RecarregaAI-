{
  "manifest_version": 3,
  "name": "RecarregaAi!",
  "version": "1.0.0",
  "description": "Limpe cache e recarregue paginas automaticamente.",
  "action": {
    "default_title": "RecarregaAi!",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "JS/background.js"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "browsingData",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
