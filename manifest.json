{
  "manifest_version": 3,
  "name": "RecarregaAi!",
  "version": "1.0.0",
  "description": "Extensao inicial do RecarregaAi! para acoes rapidas no Google Chrome.",
  "action": {
    "default_title": "RecarregaAi!",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "JS/background.js"
  },
  "permissions": [
    "activeTab",
    "storage"
  ]
}
